# Copy to `.env` and edit. Loaded automatically by docker-compose.demo.yml
# (the in-repo demo stack) and by `docker run --env-file .env ...` when
# deploying via the published image on a single host.
#
# Field naming: env vars map onto fields in the YAML config via
# pydantic-settings' `INTELLIGENCE_<SECTION>__<FIELD>` pattern (double
# underscore separates nested sections). Env values win over the YAML.

# --- Image tag pinned by the demo stack ---------------------------------------
# Pin the GHCR image tag here so `make up-demo` doesn't follow `:latest`.
# INTELLIGENCE_TAG=0.1.0

# --- Prometheus endpoint ------------------------------------------------------
# Overrides `intelligence.telemetry.prometheus.endpoint` in the YAML.
# INTELLIGENCE_TELEMETRY__PROMETHEUS__ENDPOINT=https://prometheus.example.com

# --- Prometheus auth ----------------------------------------------------------
# Name of the env var that holds the bearer token. The token itself is
# *another* var in this file — referenced by name, not pasted into the
# config. Leave both unset for unauthenticated Prometheus.
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TOKEN_ENV=PROM_TOKEN
# PROM_TOKEN=...

# Or point at a token on disk (only one of TOKEN_ENV / TOKEN_FILE).
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TOKEN_FILE=/var/run/secrets/prom

# Skip TLS verification (only for inside-cluster traffic).
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TLS_SKIP_VERIFY=true

# --- Per-request endpoint override (opt-in) -----------------------------------
# When true, train requests may set `data_source.endpoint` to redirect the
# PromQL call for that one request. Off by default: an authenticated POST
# /train can otherwise redirect outbound traffic anywhere (SSRF surface).
# INTELLIGENCE_TELEMETRY__ALLOW_ENDPOINT_OVERRIDE=true

# --- Bearer-token auth on the HTTP API ----------------------------------------
# Set the name of the env var holding the expected token; clients then
# must send `Authorization: Bearer <token>`. Probes + /docs stay open.
# INTELLIGENCE_AUTH__TOKEN_ENV=INTELLIGENCE_TOKEN
# INTELLIGENCE_TOKEN=...
