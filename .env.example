# Copy to `.env` and edit. Docker Compose loads `.env` automatically and
# passes these into the intelligence container, where pydantic-settings
# (env_nested_delimiter="__") maps them onto fields in the YAML config.
# Env values win over the YAML.

# --- Which config file to mount into the container ----------------------------
# Path on the host. Default is the shipped standalone template.
# INTELLIGENCE_CONFIG_FILE=./compose/intelligence.yaml

# --- Prometheus endpoint ------------------------------------------------------
# Overrides `intelligence.telemetry.prometheus.endpoint` in the YAML.
# INTELLIGENCE_TELEMETRY__PROMETHEUS__ENDPOINT=https://prometheus.example.com

# --- Prometheus auth ----------------------------------------------------------
# Name of the env var that holds the bearer token. The token itself is
# *another* var in this file — referenced by name, not pasted into the
# config. Leave both unset for unauthenticated Prometheus.
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TOKEN_ENV=PROM_TOKEN
# PROM_TOKEN=...

# Or point at a token on disk (only one of TOKEN_ENV / TOKEN_FILE).
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TOKEN_FILE=/var/run/secrets/prom

# Skip TLS verification (only for inside-cluster traffic).
# INTELLIGENCE_TELEMETRY__PROMETHEUS__TLS_SKIP_VERIFY=true
